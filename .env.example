# Server
HOST=0.0.0.0
PORT=1337

# New PostgreSQL database (create DB first: createdb industry_app)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/industry_app
# Or separate vars:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=industry_app
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres

# JWT for industry users (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Admin JWT (separate secret for admin routes)
ADMIN_JWT_SECRET=your-admin-jwt-secret-at-least-32-chars

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# External learners API
EXTERNAL_LEARNERS_API_URL=https://api-dev.mindmatrix.io

# CORS (comma-separated or *)
CORS_ORIGIN=*
